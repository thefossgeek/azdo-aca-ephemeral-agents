include "root" {
  path           = find_in_parent_folders("root.hcl")
  merge_strategy = "deep"
  expose         = true
}

include "common" {
  path           = find_in_parent_folders("common.hcl")
  merge_strategy = "deep"
  expose         = true
}

terraform {
  source = "${get_repo_root()}/terraform//managed-identity"
}

dependency "rg" {
  config_path = "../01resource-group"

  mock_outputs_allowed_terraform_commands = ["validate", "plan"]
  mock_outputs = {
    name = "rg-uaen-spai-dev-pipeline-mi-001"
  }
}

locals {
  location_code = include.root.inputs.location_code
  project       = include.root.inputs.project
  environment   = include.root.inputs.environment
  instance      = "001"
}

inputs = {
  name                = "id-pipeline-acrpush-${local.project}-${local.environment}-${local.location_code}-${local.instance}"
  resource_group_name = dependency.rg.outputs.name

  role_assignments = [
    {
      scope = "xxxxxx"
      role  = "Contributor"
    }
  ]
}
